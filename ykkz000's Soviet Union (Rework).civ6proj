    <InGameActionData><![CDATA[<InGameActions><UpdateDatabase id="YKKZ000_SU_RW_DATA"><Properties><LoadOrder>10</LoadOrder></Properties><Criteria>LeaderCriteria</Criteria><File>Data/YKKZ000_Districts.xml</File><File>Data/YKKZ000_UnitAbilities.xml</File><File>Data/YKKZ000_Units.xml</File><File>Data/YKKZ000_Civilizations.xml</File><File>Data/YKKZ000_Civilizations.sql</File><File>Data/YKKZ000_Leaders.xml</File><File>Data/YKKZ000_Moments.xml</File></UpdateDatabase><UpdateText id="YKKZ000_SU_RW_TEXT"><Criteria>LeaderCriteria</Criteria><File>Text/en_US/YKKZ000_ConfigText.xml</File><File>Text/en_US/YKKZ000_Text.xml</File><File>Text/zh_Hans_CN/YKKZ000_ConfigText.xml</File><File>Text/zh_Hans_CN/YKKZ000_Text.xml</File></UpdateText><UpdateIcons id="YKKZ000_SU_RW_ICON"><Criteria>LeaderCriteria</Criteria><File>Data/YKKZ000_Icon_Civilizations.xml</File><File>Data/YKKZ000_Icon_Leaders.xml</File><File>Data/YKKZ000_Icon_Districts.xml</File><File>Data/YKKZ000_Icon_Units.xml</File></UpdateIcons><UpdateArt id="YKKZ000_SU_RW_ART"><Criteria>LeaderCriteria</Criteria><File>(Mod Art Dependency File)</File></UpdateArt><UpdateColors id="YKKZ000_SU_RW_COLOR"><File>Data/YKKZ000_PlayerColors.xml</File></UpdateColors><UpdateAudio id="YKKZ000_SU_RW_AUDIO"><File>Platforms/Windows/Audio/YKKZ000_SOVIET_UNION.ini</File><File>Platforms/Windows/Audio/YKKZ000_SOVIET_UNION_Music_Bank.bnk</File><File>Platforms/Windows/Audio/YKKZ000_SOVIET_UNION_Music_Bank.txt</File><File>Platforms/Windows/Audio/SoundbanksInfo.xml</File></UpdateAudio><AddGameplayScripts id="YKKZ000_SU_RW_SCRIPT"><Properties><LoadOrder>80</LoadOrder></Properties><File>Scripts/YKKZ000_Civilizations.lua</File><File>Scripts/YKKZ000_Leaders.lua</File></AddGameplayScripts></InGameActions>]]></InGameActionData>
